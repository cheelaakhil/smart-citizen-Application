# --- SERVER CONFIGURATION ---
# The port your backend will run on
PORT=3000

# --- AI CONFIGURATION (Optional) ---
# If you have an OpenAI API Key, paste it here.
# If you leave this blank or use the dummy value below, the system will
# automatically switch to "Local Rule-Based Mode" (which is free and works for testing).
OPENAI_API_KEY=sk-dummy-key-for-local-testing